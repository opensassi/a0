{
  "name": "01-chain-simple",
  "version": "1.0.0",
  "description": "Synthetic test: simple chain of 2 prompts",
  "prompts": [
    {
      "name": "base",
      "description": "Base prompt for chaining test",
      "prompt": "BASE_TEXT"
    },
    {
      "name": "child",
      "description": "Chained child prompt",
      "chain": ["base"],
      "dependencies": [],
