{
  "name": "git",
  "version": "1.0.0",
  "description": "Git workflow skills \u2014 rebase-based single-commit-per-session workflow",
  "tools": [
    {
      "name": "status",
      "description": "Show the working tree status",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git status"
          }
        },
        "required": []
      }
    },
    {
      "name": "checkout",
      "description": "Switch branches or restore working tree files",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git checkout"
          }
        },
        "required": []
      }
    },
    {
      "name": "pull",
      "description": "Fetch from and integrate with another repository or local branch",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git pull"
          }
        },
        "required": []
      }
    },
    {
      "name": "add",
      "description": "Add file contents to the index",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git add"
          }
        },
        "required": []
      }
    },
    {
      "name": "commit",
      "description": "Record changes to the repository",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git commit"
          }
        },
        "required": []
      }
    },
    {
      "name": "rebase",
      "description": "Forward-port local commits to the updated upstream head",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git rebase"
          }
        },
        "required": []
      }
    },
    {
      "name": "push",
      "description": "Update remote refs along with associated objects",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git push"
          }
        },
        "required": []
      }
    },
    {
      "name": "fetch",
      "description": "Download objects and refs from another repository",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git fetch"
          }
        },
        "required": []
      }
    },
    {
      "name": "rev-parse",
      "description": "Pick out and massage parameters",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git rev-parse"
          }
        },
        "required": []
      },
      "subCommand": "rev-parse"
    },
    {
      "name": "worktree",
      "description": "Manage multiple working trees",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "add": { "type": "string", "description": "Path for new working tree" },
          "list": { "type": "boolean", "description": "List linked working trees" },
          "prune": { "type": "boolean", "description": "Prune stale working trees" },
          "remove": { "type": "string", "description": "Remove a working tree" },
          "args": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Additional arguments passed to git worktree"
          }
        },
        "required": []
      }
    }
  ],
  "prompts": [
    {
      "name": "start-session",
      "description": "Git session start: checkout main, pull --rebase origin main, verify working tree. The standard way to begin any git workflow.",
      "dependencies": ["system_git_status", "system_git_checkout", "system_git_pull"],
      "promptFile": "prompts/start_session.md"
    },
    {
      "name": "finish-session",
      "description": "Git session finish: add, commit, rebase onto main, push. The standard way to end and publish a git session.",
      "dependencies": ["system_git_status", "system_git_add", "system_git_commit", "system_git_checkout", "system_git_pull", "system_git_rebase", "system_git_push"],
      "promptFile": "prompts/finish_session.md"
    },
    {
      "name": "sync",
      "description": "Git sync: fetch origin and rebase onto origin/main.",
      "dependencies": ["system_git_fetch", "system_git_rebase", "system_git_status"],
      "promptFile": "prompts/sync.md"
    }
  ]
}
