      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "detach_keys": {
            "type": "string",
            "description": "Detach keys (--detach-keys)"
          },
          "index": {
            "type": "number",
            "description": "Container index (--index)"
          },
          "service": {
            "type": "string",
            "description": "Service name"
          },
          "args": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Additional arguments passed to docker compose attach"
          }
        },
        "required": []
      }
