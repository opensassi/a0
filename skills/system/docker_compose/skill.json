      "name": "build",
      "description": "Build or rebuild services",
      "systemTool": true,
      "parameters": {
        "type": "object",
        "properties": {
          "no_cache": {
            "type": "boolean",
            "description": "Do not use cache (--no-cache)"
          },
          "parallel": {
            "type": "boolean",
            "description": "Build in parallel (--parallel)"
          },
          "pull": {
            "type": "boolean",
            "description": "Always pull (--pull)"
